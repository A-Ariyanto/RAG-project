# Copy to .env before running `docker compose up`.
# Compose reads this file for both variable substitution and the app container's env.

# --- Postgres credentials ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_dev_password
POSTGRES_DB=handbook

# --- Where the app container reaches Postgres ---
# `db` is the compose service name; keep this as-is for containerised runs.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Host port to expose Postgres on, for psql from your machine ---
POSTGRES_HOST_PORT=5432

# --- Host port to expose the FastAPI /ask service on ---
APP_HOST_PORT=8000

# --- Generation provider (DeepSeek cloud API) ---
# Used by the /ask endpoint (Phase 4) and the LLM-as-judge eval (Phase 5).
# Embeddings run locally; this is the only cloud call.
DEEPSEEK_API_KEY=[INSERT_YOUR_DEEPSEEK_API_KEY_HERE]
# OpenAI-compatible endpoint + model. Swap these to point the provider interface
# at a different cheap model without touching code.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
